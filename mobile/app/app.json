{
  "expo": {
    "name": "CardioIA",
    "slug": "cardioia-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b1f3a"
    },
    "ios": { "supportsTablet": true },
    "android": {
      "permissions": ["READ_EXTERNAL_STORAGE", "READ_MEDIA_IMAGES"]
    },
    "plugins": ["expo-image-picker"]
  }
}
